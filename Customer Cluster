        "# =====================================================\n",
        "# 9. Feature importance\n",
        "# =====================================================\n",
        "\n",
        "def get_pipeline_feature_names(pipeline, numeric_features, categorical_features):\n",
        "    preprocessor = pipeline.named_steps[\"preprocess\"]\n",
        "    feature_names = []\n",
        "\n",
        "    # Numeric\n",
        "    feature_names.extend(numeric_features)\n",
        "\n",
        "    # Categorical\n",
        "    if len(categorical_features) > 0:\n",
        "        cat_encoder = preprocessor.named_transformers_[\"cat\"]\n",
        "        cat_names = cat_encoder.get_feature_names_out(categorical_features).tolist()\n",
        "        feature_names.extend(cat_names)\n",
        "\n",
        "    return feature_names\n",
        "\n",
        "feature_names = get_pipeline_feature_names(\n",
        "    best_model,\n",
        "    risk_numeric_features,\n",
        "    risk_categorical_features\n",
        ")\n",
        "\n",
        "model_step = best_model.named_steps[\"model\"]\n",
        "\n",
        "if hasattr(model_step, \"feature_importances_\"):\n",
        "    importances = model_step.feature_importances_\n",
        "elif hasattr(model_step, \"coef_\"):\n",
        "    importances = np.abs(model_step.coef_[0])\n",
        "else:\n",
        "    importances = None\n",
        "\n",
        "if importances is not None:\n",
        "    feature_importance = pd.DataFrame({\n",
        "        \"feature\": feature_names,\n",
        "        \"importance\": importances\n",
        "    }).sort_values(\"importance\", ascending=False)\n",
        "\n",
        "    display(feature_importance.head(30))\n",
        "else:\n",
        "    print(\"Selected model does not provide feature importance.\")"
      ]
    },
