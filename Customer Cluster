      "source": [
        "# =====================================================\n",
        "# 3. Feature engineering\n",
        "# =====================================================\n",
        "# Mục tiêu:\n",
        "# - Tạo log features cho các cột tiền\n",
        "# - Clip outlier cho ratio / overdue / count\n",
        "# - Chuẩn hóa categorical\n",
        "# - Giữ customer_key và target_risk\n",
        "\n",
        "df = df_raw.copy()\n",
        "\n",
        "if \"customer_key\" not in df.columns:\n",
        "    raise ValueError(\"customer_key column is required for tracing ML output.\")\n",
        "\n",
        "if \"target_risk\" not in df.columns:\n",
        "    raise ValueError(\"target_risk column is required for supervised risk prediction.\")\n",
        "\n",
        "def to_numeric_safe(series):\n",
        "    return pd.to_numeric(series, errors=\"coerce\")\n",
        "\n",
        "def add_log_feature(df, source_col, new_col):\n",
        "    if source_col in df.columns:\n",
        "        df[source_col] = to_numeric_safe(df[source_col]).fillna(0)\n",
        "        df[source_col] = df[source_col].clip(lower=0)\n",
        "        df[new_col] = np.log1p(df[source_col])\n",
        "    return df\n",
        "\n",
        "def add_clipped_feature(df, source_col, new_col, lower=None, upper=None, q_low=0.01, q_high=0.99):\n",
        "    if source_col in df.columns:\n",
        "        s = to_numeric_safe(df[source_col]).replace([np.inf, -np.inf], np.nan).fillna(0)\n",
        "        # Ensure 's' is a float type before clipping, as quantile results are floats\n",
        "        s = s.astype(float)\n",
        "\n",
        "        if lower is None:\n",
        "            lower = s.quantile(q_low)\n",
        "        if upper is None:\n",
        "            upper = s.quantile(q_high)\n",
        "\n",
        "        df[new_col] = s.clip(lower, upper)\n",
        "    return df\n",
        "\n",
        "# -----------------------------\n",
        "# 3.1 Log transform amount / salary columns\n",
        "# -----------------------------\n",
        "\n",
        "money_log_map = {\n",
        "    \"total_requested_amount\": \"total_requested_amount_log\",\n",
        "    \"total_disbursed_amount\": \"total_disbursed_amount_log\",\n",
        "    \"total_remaining_principal\": \"total_remaining_principal_log\",\n",
        "    \"avg_requested_amount\": \"avg_requested_amount_log\",\n",
        "    \"avg_disbursed_amount\": \"avg_disbursed_amount_log\",\n",
        "    \"avg_remaining_principal\": \"avg_remaining_principal_log\",\n",
        "    \"avg_salary\": \"avg_salary_log\",\n",
        "}\n",
        "\n",
        "for source_col, new_col in money_log_map.items():\n",
        "    df = add_log_feature(df, source_col, new_col)\n",
        "\n",
        "# -----------------------------\n",
        "# 3.2 Clip ratio columns\n",
        "# -----------------------------\n",
        "\n",
        "# Business clipping for loan-to-income ratio\n",
        "if \"avg_loan_to_income_ratio\" in df.columns:\n",
        "    df[\"avg_loan_to_income_ratio\"] = to_numeric_safe(df[\"avg_loan_to_income_ratio\"]).replace([np.inf, -np.inf], np.nan).fillna(0)\n",
        "    df[\"avg_loan_to_income_ratio_clipped\"] = df[\"avg_loan_to_income_ratio\"].clip(0, 20)\n",
        "\n",
        "# Percentile clipping for outstanding ratios\n",
        "df = add_clipped_feature(df, \"avg_outstanding_ratio\", \"avg_outstanding_ratio_clipped\", lower=0, upper=None)\n",
        "df = add_clipped_feature(df, \"customer_outstanding_ratio\", \"customer_outstanding_ratio_clipped\", lower=0, upper=None)\n",
        "\n",
        "# -----------------------------\n",
        "# 3.3 Clip repayment behavior / count columns\n",
        "# -----------------------------\n",
        "\n",
        "df = add_clipped_feature(df, \"max_overdue_days\", \"max_overdue_days_clipped\", lower=0, upper=None)\n",
        "df = add_clipped_feature(df, \"avg_overdue_days\", \"avg_overdue_days_clipped\", lower=0, upper=None)\n",
        "\n",
        "df = add_clipped_feature(df, \"total_loans\", \"total_loans_clipped\", lower=0, upper=None)\n",
        "df = add_clipped_feature(df, \"overdue_count\", \"overdue_count_clipped\", lower=0, upper=None)\n",
        "df = add_clipped_feature(df, \"late_payment_count\", \"late_payment_count_clipped\", lower=0, upper=None)\n",
        "\n",
        "# -----------------------------\n",
        "# 3.4 Clean basic numeric columns\n",
        "# -----------------------------\n",
        "\n",
        "basic_numeric_cols = [\n",
        "    \"avg_credit_score\",\n",
        "    \"avg_loan_term_months\",\n",
        "    \"age\"\n",
        "]\n",
        "\n",
        "for col in basic_numeric_cols:\n",
        "    if col in df.columns:\n",
        "        df[col] = to_numeric_safe(df[col]).replace([np.inf, -np.inf], np.nan)\n",
        "\n",
        "if \"age\" in df.columns:\n",
        "    # Age outside normal loan customer range is set to median\n",
        "    df[\"age\"] = df[\"age\"].where(df[\"age\"].between(18, 90), np.nan)\n",
        "    df[\"age\"] = df[\"age\"].fillna(df[\"age\"].median())\n",
        "\n",
        "# -----------------------------\n",
        "# 3.5 Clean categorical columns\n",
        "# -----------------------------\n",
        "\n",
        "categorical_candidates = [\n",
        "    \"gender\",\n",
        "    \"age_group\",\n",
        "    \"city_name\",\n",
        "    \"job_name\",\n",
        "    \"residence_type\",\n",
        "    \"income_bracket\",\n",
        "    \"credit_score_group\"\n",
        "]\n",
        "\n",
        "for col in categorical_candidates:\n",
        "    if col in df.columns:\n",
        "        df[col] = df[col].astype(\"object\").fillna(\"Unknown\").astype(str).str.strip()\n",
        "\n",
        "# -----------------------------\n",
        "# 3.6 Final checks\n",
        "# -----------------------------\n",
        "\n",
        "print(\"Feature-engineered data shape:\", df.shape)\n",
        "\n",
        "created_cols = [\n",
        "    c for c in df.columns\n",
        "    if c.endswith(\"_log\") or c.endswith(\"_clipped\")\n",
        "]\n",
        "\n",
        "print(\"\\nCreated log/clipped columns:\")\n",
        "print(created_cols)\n",
        "\n",
        "display(df.head())"
      ]
    },
