        "\n",
        "def risk_band(prob):\n",
        "    if prob < selected_threshold:\n",
        "        return \"Low Risk\"\n",
        "    elif prob < 0.55:\n",
        "        return \"Medium Risk\"\n",
        "    elif prob < 0.70:\n",
        "        return \"High Risk\"\n",
        "    else:\n",
        "        return \"Very High Risk\"\n",
        "\n",
        "customer_ml_scoring = pd.DataFrame({\n",
        "    \"customer_key\": customer_keys.values if hasattr(customer_keys, \"values\") else customer_keys,\n",
        "    \"risk_probability\": all_risk_probability,\n",
        "    \"predicted_risk\": all_predicted_risk\n",
        "})\n",
        "\n",
        "customer_ml_scoring[\"risk_band\"] = customer_ml_scoring[\"risk_probability\"].apply(risk_band)\n",
        "customer_ml_scoring[\"model_name\"] = best_model_name\n",
        "customer_ml_scoring[\"selected_threshold\"] = selected_threshold\n",
