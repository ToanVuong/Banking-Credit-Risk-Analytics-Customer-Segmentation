        "# =====================================================\n",
        "# 5. Prepare data for supervised risk prediction\n",
        "# =====================================================\n",
        "\n",
        "model_df = df[\n",
        "    [\"customer_key\", \"target_risk\"] + risk_numeric_features + risk_categorical_features\n",
        "].copy()\n",
        "\n",
        "# Clean numeric\n",
        "for col in risk_numeric_features:\n",
        "    model_df[col] = pd.to_numeric(model_df[col], errors=\"coerce\")\n",
        "\n",
        "model_df[risk_numeric_features] = model_df[risk_numeric_features].replace([np.inf, -np.inf], np.nan)\n",
        "model_df[risk_numeric_features] = model_df[risk_numeric_features].fillna(0)\n",
        "\n",
        "# Clean categorical and group high-cardinality variables\n",
        "def group_rare_categories(series, min_count=20, top_n=25):\n",
        "    s = series.astype(\"object\").fillna(\"Unknown\").astype(str).str.strip()\n",
        "    counts = s.value_counts(dropna=False)\n",
        "    frequent = counts[counts >= min_count].index.tolist()[:top_n]\n",
        "    return s.where(s.isin(frequent), \"Other\")\n",
        "\n",
        "high_cardinality_cols = [\"city_name\", \"job_name\"]\n",
        "\n",
        "for col in risk_categorical_features:\n",
        "    if col in high_cardinality_cols:\n",
        "        model_df[col] = group_rare_categories(model_df[col], min_count=20, top_n=25)\n",
        "    else:\n",
        "        model_df[col] = model_df[col].astype(\"object\").fillna(\"Unknown\").astype(str).str.strip()\n",
        "\n",
        "X = model_df[risk_numeric_features + risk_categorical_features]\n",
        "y = model_df[\"target_risk\"].astype(int)\n",
        "customer_keys = model_df[\"customer_key\"]\n",
        "\n",
        "print(\"Final X shape:\", X.shape)\n",
        "\n",
        "print(\"\\nTarget distribution:\")\n",
        "display(y.value_counts(normalize=True).round(4).to_frame(\"ratio\"))\n",
        "display(y.value_counts().to_frame(\"count\"))"
      ]
    },
