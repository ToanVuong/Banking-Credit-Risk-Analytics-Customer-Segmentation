      "source": [
        "# =====================================================\n",
        "# UNSUPERVISED LEARNING - CUSTOMER SEGMENTATION\n",
        "# =====================================================\n",
        "# Notes:\n",
        "# - target_risk, risk_probability, predicted_risk, and risk_band are NOT used for K-Means training.\n",
        "# - They are used only after clustering for validation and business interpretation.\n",
        "\n",
        "# =====================================================\n",
        "# 1. Prepare dataframe for clustering\n",
        "# =====================================================\n",
        "\n",
        "df_unsupervised = df.copy()\n",
        "\n",
        "# Merge scoring result only for later validation/profile, not for clustering input\n",
        "if \"customer_ml_scoring\" in globals() and \"customer_key\" in customer_ml_scoring.columns:\n",
        "    scoring_cols = [\n",
        "        \"risk_probability\",\n",
        "        \"predicted_risk\",\n",
        "        \"risk_band\"\n",
        "    ]\n",
        "\n",
        "    scoring_cols = [\n",
        "        c for c in scoring_cols\n",
        "        if c in customer_ml_scoring.columns and c not in df_unsupervised.columns\n",
        "    ]\n",
        "\n",
        "    if len(scoring_cols) > 0:\n",
        "        df_unsupervised = df_unsupervised.merge(\n",
        "            customer_ml_scoring[[\"customer_key\"] + scoring_cols],\n",
        "            on=\"customer_key\",\n",
        "            how=\"left\"\n",
        "        )\n",
        "\n",
        "print(\"df_unsupervised shape:\", df_unsupervised.shape)\n",
        "\n",
        "# =====================================================\n",
        "# 2. Choose clustering scope\n",
        "# =====================================================\n",
        "\n",
        "CLUSTER_SCOPE = \"all\"\n",
        "# CLUSTER_SCOPE = \"predicted_risk\"\n",
        "\n",
        "if CLUSTER_SCOPE == \"predicted_risk\":\n",
        "    if \"predicted_risk\" not in df_unsupervised.columns:\n",
        "        raise ValueError(\"predicted_risk column not found. Run risk prediction/scoring first.\")\n",
        "\n",
        "    original_cluster_df = df_unsupervised[\n",
        "        df_unsupervised[\"predicted_risk\"] == 1\n",
        "    ].copy()\n",
        "else:\n",
        "    original_cluster_df = df_unsupervised.copy()\n",
        "\n",
        "print(\"Clustering scope:\", CLUSTER_SCOPE)\n",
        "print(\"original_cluster_df shape:\", original_cluster_df.shape)\n",
        "\n",
        "# =====================================================\n",
        "# 3. Encode categorical variables\n",
        "# =====================================================\n",
        "\n",
        "categorical_cols_for_encoding = [\n",
        "    \"gender\",\n",
        "    \"age_group\",\n",
        "    \"city_name\",\n",
        "    \"job_name\",\n",
        "    \"residence_type\",\n",
        "    \"income_bracket\",\n",
        "    \"credit_score_group\"\n",
        "]\n",
        "\n",
        "categorical_cols_for_encoding = [\n",
        "    c for c in categorical_cols_for_encoding\n",
        "    if c in original_cluster_df.columns\n",
        "]\n",
        "\n",
        "df_encoded = pd.get_dummies(\n",
        "    original_cluster_df,\n",
        "    columns=categorical_cols_for_encoding,\n",
        "    drop_first=True,\n",
        "    dtype=int\n",
        ")\n",
        "\n",
        "print(\"df_encoded shape:\", df_encoded.shape)\n",
        "\n",
        "# =====================================================\n",
        "# 4. Define selected features for K-Means\n",
        "# =====================================================\n",
        "# These features are the raw/before-scaling inputs for K-Means.\n",
        "\n",
        "selected_clustering_features = [\n",
        "    # repayment behavior\n",
        "    \"late_payment_count_clipped\",\n",
        "    \"max_overdue_days_clipped\",\n",
        "    \"avg_overdue_days_clipped\",\n",
        "\n",
        "    # customer profile / financial profile\n",
        "    \"age\",\n",
        "    \"avg_salary_log\",\n",
        "    \"avg_credit_score\",\n",
        "    \"avg_outstanding_ratio_clipped\",\n",
        "\n",
        "    # selected dummy features\n",
        "    \"job_name_Nhân viên chính thức\",\n",
        "    \"residence_type_Sở hữu cá nhân\",\n",
        "    \"income_bracket_5-10m\"\n",
        "]\n",
        "\n",
        "selected_clustering_features = [\n",
        "    c for c in selected_clustering_features\n",
        "    if c in df_encoded.columns\n",
        "]\n",
        "\n",
        "if len(selected_clustering_features) < 2:\n",
        "    raise ValueError(\"Not enough clustering features found in df_encoded.\")\n",
        "\n",
        "print(\"Selected clustering features:\")\n",
        "print(selected_clustering_features)\n",
        "\n",
        "# =====================================================\n",
        "# 5. Safety check: avoid target leakage in K-Means\n",
        "# =====================================================\n",
        "\n",
        "target_related_cols = [\n",
        "    \"target_risk\",\n",
        "    \"risk_probability\",\n",
        "    \"predicted_risk\",\n",
        "    \"risk_band\"\n",
        "]\n",
        "\n",
        "leakage_features = [\n",
        "    col for col in target_related_cols\n",
        "    if col in selected_clustering_features\n",
        "]\n",
        "\n",
        "if len(leakage_features) > 0:\n",
        "    raise ValueError(f\"These columns must not be used as K-Means features: {leakage_features}\")\n",
        "\n",
        "# =====================================================\n",
        "# 6. Create before-scaling and scaled clustering features\n",
        "# =====================================================\n",
        "\n",
        "cluster_features_raw = df_encoded[selected_clustering_features].copy()\n",
        "\n",
        "for col in cluster_features_raw.columns:\n",
        "    cluster_features_raw[col] = pd.to_numeric(\n",
        "        cluster_features_raw[col],\n",
        "        errors=\"coerce\"\n",
        "    )\n",
        "\n",
        "cluster_features_raw = cluster_features_raw.replace(\n",
        "    [np.inf, -np.inf],\n",
        "    np.nan\n",
        ")\n",
        "\n",
        "cluster_features_raw = cluster_features_raw.fillna(\n",
        "    cluster_features_raw.median(numeric_only=True)\n",
        ")\n",
        "\n",
        "print(\"\\nCluster features BEFORE scaling:\")\n",
        "display(cluster_features_raw.head())\n",
        "\n",
        "scaler = StandardScaler()\n",
        "\n",
        "cluster_features_scaled = pd.DataFrame(\n",
        "    scaler.fit_transform(cluster_features_raw),\n",
        "    columns=cluster_features_raw.columns,\n",
        "    index=cluster_features_raw.index\n",
        ")\n",
        "\n",
        "print(\"\\nCluster features AFTER scaling:\")\n",
        "display(cluster_features_scaled.head())\n",
        "\n",
        "# =====================================================\n",
        "# 7. PCA with target variance\n",
        "# =====================================================\n",
        "\n",
        "pca_full = PCA(random_state=RANDOM_STATE)\n",
        "pca_full.fit(cluster_features_scaled)\n",
        "\n",
        "cumulative_variance = np.cumsum(pca_full.explained_variance_ratio_)\n",
        "\n",
        "explained_variance_df = pd.DataFrame({\n",
        "    \"n_components\": range(1, len(cumulative_variance) + 1),\n",
        "    \"cumulative_explained_variance\": cumulative_variance\n",
        "})\n",
        "\n",
        "display(explained_variance_df)\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "sns.lineplot(\n",
        "    data=explained_variance_df,\n",
        "    x=\"n_components\",\n",
        "    y=\"cumulative_explained_variance\",\n",
        "    marker=\"o\"\n",
        ")\n",
        "plt.axhline(\n",
        "    y=PCA_TARGET_VARIANCE,\n",
        "    linestyle=\"--\",\n",
        "    label=f\"{int(PCA_TARGET_VARIANCE * 100)}% variance threshold\"\n",
        ")\n",
        "plt.title(\"Cumulative Explained Variance by PCA Components\")\n",
        "plt.xlabel(\"Number of PCA Components\")\n",
        "plt.ylabel(\"Cumulative Explained Variance\")\n",
        "plt.grid(True)\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "N_PCA_COMPONENTS = np.argmax(cumulative_variance >= PCA_TARGET_VARIANCE) + 1\n",
        "\n",
        "print(\"Selected PCA components:\", N_PCA_COMPONENTS)\n",
        "print(\"Selected cumulative variance:\", cumulative_variance[N_PCA_COMPONENTS - 1])\n",
        "\n",
        "pca = PCA(n_components=N_PCA_COMPONENTS, random_state=RANDOM_STATE)\n",
        "\n",
        "PCA_ds = pd.DataFrame(\n",
        "    pca.fit_transform(cluster_features_scaled),\n",
        "    columns=[f\"PC{i}\" for i in range(1, N_PCA_COMPONENTS + 1)],\n",
        "    index=cluster_features_scaled.index\n",
        ")\n",
        "\n",
        "print(f\"\\nExplained variance ratio for {N_PCA_COMPONENTS} PCA components:\")\n",
        "print(pca.explained_variance_ratio_)\n",
        "\n",
        "print(f\"\\nCumulative explained variance for {N_PCA_COMPONENTS} PCA components:\")\n",
        "print(pca.explained_variance_ratio_.sum())\n",
        "\n",
        "display(PCA_ds.head())\n",
        "\n",
        "# =====================================================\n",
        "# 8. Elbow Method\n",
        "# =====================================================\n",
        "\n",
        "sum_of_squared_distances = []\n",
        "\n",
        "for k in range(1, MAX_CLUSTERS + 1):\n",
        "    kmeans = KMeans(\n",
        "        n_clusters=k,\n",
        "        init=\"k-means++\",\n",
        "        random_state=RANDOM_STATE,\n",
        "        n_init=10\n",
        "    )\n",
        "    kmeans.fit(PCA_ds)\n",
        "    sum_of_squared_distances.append(kmeans.inertia_)\n",
        "\n",
        "plt.figure(figsize=(10, 5))\n",
        "plt.plot(\n",
        "    range(1, MAX_CLUSTERS + 1),\n",
        "    sum_of_squared_distances,\n",
        "    marker=\"o\",\n",
        "    linestyle=\"--\"\n",
        ")\n",
        "plt.title(\"Elbow Method\")\n",
        "plt.xlabel(\"Number of Clusters\")\n",
        "plt.ylabel(\"Within-Cluster Sum of Squares\")\n",
        "plt.grid(True)\n",
        "plt.show()\n",
        "\n",
        "# =====================================================\n",
        "# 9. Final K-Means model\n",
        "# =====================================================\n",
        "\n",
        "kmeans = KMeans(\n",
        "    n_clusters=FINAL_SEGMENTATION_K,\n",
        "    init=\"k-means++\",\n",
        "    random_state=RANDOM_STATE,\n",
        "    n_init=10\n",
        ")\n",
        "\n",
        "predicted_labels = kmeans.fit_predict(PCA_ds)\n",
        "\n",
        "PCA_ds[\"Cluster\"] = predicted_labels\n",
        "\n",
        "# Add cluster labels to original dataframe and encoded dataframe\n",
        "original_cluster_df = original_cluster_df.copy()\n",
        "original_cluster_df[\"Cluster\"] = predicted_labels\n",
        "\n",
        "df_encoded_clustered = df_encoded.copy()\n",
        "df_encoded_clustered[\"Cluster\"] = predicted_labels\n",
        "\n",
        "# =====================================================\n",
        "# 10. Silhouette Score and cluster distribution\n",
        "# =====================================================\n",
        "\n",
        "pca_cols = [col for col in PCA_ds.columns if col.startswith(\"PC\")]\n",
        "\n",
        "sil_score = silhouette_score(\n",
        "    PCA_ds[pca_cols],\n",
        "    predicted_labels\n",
        ")\n",
        "\n",
        "print(\"\\nSilhouette Score:\", sil_score)\n",
        "\n",
        "cluster_distribution = (\n",
        "    original_cluster_df[\"Cluster\"]\n",
        "    .value_counts()\n",
        "    .sort_index()\n",
        "    .to_frame(\"customer_count\")\n",
        ")\n",
        "\n",
        "cluster_distribution[\"customer_pct\"] = (\n",
        "    cluster_distribution[\"customer_count\"] / len(original_cluster_df)\n",
        ").round(4)\n",
        "\n",
        "display(cluster_distribution)\n",
        "\n",
        "# =====================================================\n",
        "# 11. Visualize clusters in PCA space\n",
        "# =====================================================\n",
        "\n",
        "if {\"PC1\", \"PC2\"}.issubset(PCA_ds.columns):\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    sns.scatterplot(\n",
        "        data=PCA_ds,\n",
        "        x=\"PC1\",\n",
        "        y=\"PC2\",\n",
        "        hue=\"Cluster\",\n",
        "        palette=\"tab10\",\n",
        "        s=60\n",
        "    )\n",
        "    plt.title(\"Customer Segments by PCA Components\")\n",
        "    plt.xlabel(\"PC1\")\n",
        "    plt.ylabel(\"PC2\")\n",
        "    plt.legend(title=\"Cluster\")\n",
        "    plt.grid(True)\n",
        "    plt.show()\n",
        "else:\n",
        "    print(\"2D PCA chart skipped because fewer than 2 PCA components were selected.\")\n",
        "\n",
        "if \"PC3\" in PCA_ds.columns:\n",
        "    fig = plt.figure(figsize=(10, 7))\n",
        "    ax = fig.add_subplot(111, projection=\"3d\")\n",
        "\n",
        "    ax.scatter(\n",
        "        PCA_ds[\"PC1\"],\n",
        "        PCA_ds[\"PC2\"],\n",
        "        PCA_ds[\"PC3\"],\n",
        "        c=PCA_ds[\"Cluster\"],\n",
        "        s=40\n",
        "    )\n",
        "\n",
        "    ax.set_title(\"Customer Segments in 3D PCA Space\")\n",
        "    ax.set_xlabel(\"PC1\")\n",
        "    ax.set_ylabel(\"PC2\")\n",
        "    ax.set_zlabel(\"PC3\")\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "# =====================================================\n",
        "# 12. Assign business cluster names\n",
        "# =====================================================\n",
        "# Adjust these names after reviewing cluster_avg_profile_before_scaling.\n",
        "\n",
        "cluster_name_map = {\n",
        "    0: \"Low Risk Stable Customers\",\n",
        "    1: \"Main Portfolio Medium Risk\",\n",
        "    2: \"Main Portfolio Watchlist\",\n",
        "    3: \"High Overdue Risk\"\n",
        "}\n",
        "\n",
        "original_cluster_df[\"cluster_id\"] = original_cluster_df[\"Cluster\"]\n",
        "original_cluster_df[\"cluster_name\"] = original_cluster_df[\"cluster_id\"].map(\n",
        "    cluster_name_map\n",
        ")\n",
        "\n",
        "original_cluster_df[\"cluster_name\"] = original_cluster_df[\"cluster_name\"].fillna(\n",
        "    \"Cluster \" + original_cluster_df[\"cluster_id\"].astype(str)\n",
        ")\n",
        "\n",
        "# =====================================================\n",
        "# 13. Final customer segmentation result\n",
        "# =====================================================\n",
        "\n",
        "customer_segmentation_result = original_cluster_df[\n",
        "    [\n",
        "        \"customer_key\",\n",
        "        \"cluster_id\",\n",
        "        \"cluster_name\"\n",
        "    ]\n",
        "].copy()\n",
        "\n",
        "display(customer_segmentation_result.head())\n",
        "\n",
        "print(\"\\nCustomer segmentation result shape:\", customer_segmentation_result.shape)\n",
        "\n",
        "# =====================================================\n",
        "# 14. Cluster average profile using BEFORE-SCALING features\n",
        "# =====================================================\n",
        "# This table is created after clustering.\n",
        "# It uses raw feature values before StandardScaler, so the averages are easier to interpret.\n",
        "# Extra validation columns are included only for interpretation and were not used to fit K-Means.\n",
        "\n",
        "business_profile_features = [\n",
        "    # repayment behavior\n",
        "    \"late_payment_count_clipped\",\n",
        "    \"max_overdue_days_clipped\",\n",
        "    \"avg_overdue_days_clipped\",\n",
        "    \"overdue_count_clipped\",\n",
        "\n",
        "    # credit quality\n",
        "    \"avg_credit_score\",\n",
        "\n",
        "    # customer profile\n",
        "    \"age\",\n",
        "    \"avg_salary_log\",\n",
        "\n",
        "    # loan / exposure behavior\n",
        "    \"total_loans_clipped\",\n",
        "    \"total_requested_amount_log\",\n",
        "    \"total_disbursed_amount_log\",\n",
        "    \"total_remaining_principal_log\",\n",
        "    \"avg_requested_amount_log\",\n",
        "    \"avg_disbursed_amount_log\",\n",
        "    \"avg_remaining_principal_log\",\n",
        "    \"avg_loan_to_income_ratio_clipped\",\n",
        "    \"avg_outstanding_ratio_clipped\",\n",
        "    \"customer_outstanding_ratio_clipped\",\n",
        "\n",
        "    # validation only\n",
        "    \"target_risk\",\n",
        "    \"risk_probability\"\n",
        "]\n",
        "\n",
        "profile_features_before_scaling = list(dict.fromkeys(\n",
        "    selected_clustering_features + business_profile_features\n",
        "))\n",
        "\n",
        "profile_features_before_scaling = [\n",
        "    col for col in profile_features_before_scaling\n",
        "    if col in df_encoded_clustered.columns or col in original_cluster_df.columns\n",
        "]\n",
        "\n",
        "profile_source_before_scaling = pd.DataFrame(index=original_cluster_df.index)\n",
        "\n",
        "for col in profile_features_before_scaling:\n",
        "    if col in df_encoded_clustered.columns:\n",
        "        profile_source_before_scaling[col] = df_encoded_clustered[col].values\n",
        "    else:\n",
        "        profile_source_before_scaling[col] = original_cluster_df[col].values\n",
        "\n",
        "for col in profile_features_before_scaling:\n",
        "    profile_source_before_scaling[col] = pd.to_numeric(\n",
        "        profile_source_before_scaling[col],\n",
        "        errors=\"coerce\"\n",
        "    )\n",
        "\n",
        "profile_source_before_scaling[\"cluster_id\"] = original_cluster_df[\"cluster_id\"].values\n",
        "profile_source_before_scaling[\"cluster_name\"] = original_cluster_df[\"cluster_name\"].values\n",
        "\n",
        "cluster_avg_profile_before_scaling = (\n",
        "    profile_source_before_scaling\n",
        "    .groupby([\"cluster_id\", \"cluster_name\"])[profile_features_before_scaling]\n",
        "    .mean()\n",
        "    .round(4)\n",
        "    .reset_index()\n",
        ")\n",
        "\n",
        "cluster_count = (\n",
        "    original_cluster_df\n",
        "    .groupby([\"cluster_id\", \"cluster_name\"])\n",
        "    .size()\n",
        "    .reset_index(name=\"customer_count\")\n",
        ")\n",
        "\n",
        "cluster_avg_profile_before_scaling = cluster_count.merge(\n",
        "    cluster_avg_profile_before_scaling,\n",
        "    on=[\"cluster_id\", \"cluster_name\"],\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "cluster_avg_profile_before_scaling[\"customer_pct\"] = (\n",
        "    cluster_avg_profile_before_scaling[\"customer_count\"] / len(original_cluster_df)\n",
        ").round(4)\n",
        "\n",
        "first_cols = [\"cluster_id\", \"cluster_name\", \"customer_count\", \"customer_pct\"]\n",
        "other_cols = [\n",
        "    c for c in cluster_avg_profile_before_scaling.columns\n",
        "    if c not in first_cols\n",
        "]\n",
        "\n",
        "cluster_avg_profile_before_scaling = (\n",
        "    cluster_avg_profile_before_scaling[first_cols + other_cols]\n",
        ")\n",
        "\n",
        "display(cluster_avg_profile_before_scaling)\n"
      ]
    },
