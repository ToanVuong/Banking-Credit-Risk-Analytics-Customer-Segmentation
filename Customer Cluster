      "source": [
        "# =====================================================\n",
        "# 7. Model comparison with Pipeline\n",
        "# =====================================================\n",
        "# Pipeline handles:\n",
        "# - StandardScaler for numeric features\n",
        "# - OneHotEncoder for categorical features\n",
        "# - Model training\n",
        "\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers=[\n",
        "        (\"num\", StandardScaler(), risk_numeric_features),\n",
        "        (\"cat\", OneHotEncoder(handle_unknown=\"ignore\", drop=None), risk_categorical_features)\n",
        "    ]\n",
        ")\n",
        "\n",
        "model_candidates = {\n",
        "    \"Logistic Regression\": {\n",
        "        \"model\": LogisticRegression(\n",
        "            max_iter=3000,\n",
        "            class_weight=\"balanced\",\n",
        "            random_state=RANDOM_STATE\n",
        "        ),\n",
        "        \"params\": {\n",
        "            \"model__C\": [0.01, 0.05, 0.1, 0.5, 1, 2, 5, 10],\n",
        "            \"model__solver\": [\"lbfgs\", \"liblinear\"]\n",
        "        }\n",
        "    },\n",
        "\n",
        "    \"Random Forest\": {\n",
        "        \"model\": RandomForestClassifier(\n",
        "            random_state=RANDOM_STATE,\n",
        "            class_weight=\"balanced_subsample\"\n",
        "        ),\n",
        "        \"params\": {\n",
        "            \"model__n_estimators\": [100, 200, 300, 500],\n",
        "            \"model__max_depth\": [4, 5, 7, 10, 15, None],\n",
        "            \"model__min_samples_split\": [2, 5, 10, 20],\n",
        "            \"model__min_samples_leaf\": [1, 2, 5, 10],\n",
        "            \"model__max_features\": [\"sqrt\", \"log2\", None],\n",
        "            \"model__bootstrap\": [True, False]\n",
        "        }\n",
        "    },\n",
        "\n",
        "    \"Extra Trees\": {\n",
        "        \"model\": ExtraTreesClassifier(\n",
        "            random_state=RANDOM_STATE,\n",
        "            class_weight=\"balanced\"\n",
        "        ),\n",
        "        \"params\": {\n",
        "            \"model__n_estimators\": [100, 200, 300, 500],\n",
        "            \"model__max_depth\": [4, 5, 7, 10, 15, None],\n",
        "            \"model__min_samples_split\": [2, 5, 10, 20],\n",
        "            \"model__min_samples_leaf\": [1, 2, 5, 10],\n",
        "            \"model__max_features\": [\"sqrt\", \"log2\", None],\n",
        "            \"model__bootstrap\": [False, True]\n",
        "        }\n",
        "    },\n",
        "\n",
        "    \"Gradient Boosting\": {\n",
        "        \"model\": GradientBoostingClassifier(\n",
        "            random_state=RANDOM_STATE\n",
        "        ),\n",
        "        \"params\": {\n",
        "            \"model__n_estimators\": [50, 100, 200],\n",
        "            \"model__learning_rate\": [0.01, 0.05, 0.1],\n",
        "            \"model__max_depth\": [2, 3, 4],\n",
        "            \"model__min_samples_leaf\": [1, 3, 5],\n",
        "            \"model__subsample\": [0.7, 0.9, 1.0]\n",
        "        }\n",
        "    }\n",
        "}\n",
        "\n",
        "model_results = []\n",
        "best_models = {}\n",
        "\n",
        "for model_name, spec in model_candidates.items():\n",
        "    print(f\"\\nTraining model: {model_name}\")\n",
        "\n",
        "    pipe = Pipeline(\n",
        "        steps=[\n",
        "            (\"preprocess\", preprocessor),\n",
        "            (\"model\", spec[\"model\"])\n",
        "        ]\n",
        "    )\n",
        "\n",
        "    search = RandomizedSearchCV(\n",
        "        estimator=pipe,\n",
        "        param_distributions=spec[\"params\"],\n",
        "        n_iter=N_ITER_SEARCH,\n",
        "        scoring=\"roc_auc\",\n",
        "        cv=CV_FOLDS,\n",
        "        random_state=RANDOM_STATE,\n",
        "        n_jobs=-1,\n",
        "        verbose=0,\n",
        "        return_train_score=True\n",
        "    )\n",
        "\n",
        "    search.fit(X_train, y_train)\n",
        "\n",
        "    fitted_model = search.best_estimator_\n",
        "    best_models[model_name] = fitted_model\n",
        "\n",
        "    y_prob = fitted_model.predict_proba(X_test)[:, 1]\n",
        "    y_pred_05 = (y_prob >= 0.50).astype(int)\n",
        "\n",
        "    result = {\n",
        "        \"model_name\": model_name,\n",
        "        \"best_cv_roc_auc\": search.best_score_,\n",
        "        \"test_roc_auc\": roc_auc_score(y_test, y_prob),\n",
        "        \"test_pr_auc\": average_precision_score(y_test, y_prob),\n",
        "        \"balanced_accuracy_05\": balanced_accuracy_score(y_test, y_pred_05),\n",
        "        \"precision_risk_05\": precision_score(y_test, y_pred_05, zero_division=0),\n",
        "        \"recall_risk_05\": recall_score(y_test, y_pred_05, zero_division=0),\n",
        "        \"f1_risk_05\": f1_score(y_test, y_pred_05, zero_division=0),\n",
        "        \"best_params\": search.best_params_\n",
        "    }\n",
        "\n",
        "    model_results.append(result)\n",
        "\n",
        "model_results_df = pd.DataFrame(model_results).sort_values(\n",
        "    by=[\"test_roc_auc\", \"test_pr_auc\"],\n",
        "    ascending=False\n",
        ")\n",
        "\n",
        "display(model_results_df)\n",
        "\n",
        "best_model_name = model_results_df.iloc[0][\"model_name\"]\n",
        "best_model = best_models[best_model_name]\n",
        "\n",
        "print(\"\\nSelected best model:\", best_model_name)\n",
        "print(\"Best parameters:\")\n",
        "print(model_results_df.iloc[0][\"best_params\"])"
      ]
    },
