        "# 8. Evaluate best model and tune threshold\n",
        "# =====================================================\n",
        "\n",
        "y_prob_test = best_model.predict_proba(X_test)[:, 1]\n",
        "y_pred_test_05 = (y_prob_test >= 0.50).astype(int)\n",
        "\n",
        "print(\"Default threshold = 0.50\")\n",
        "print(\"ROC-AUC:\", round(roc_auc_score(y_test, y_prob_test), 4))\n",
        "print(\"PR-AUC:\", round(average_precision_score(y_test, y_prob_test), 4))\n",
        "print(\"Balanced Accuracy:\", round(balanced_accuracy_score(y_test, y_pred_test_05), 4))\n",
        "print(\"\\nClassification report:\")\n",
        "print(classification_report(y_test, y_pred_test_05))\n",
        "print(\"\\nConfusion matrix:\")\n",
        "print(confusion_matrix(y_test, y_pred_test_05))\n",
        "\n",
        "threshold_results = []\n",
        "\n",
        "for threshold in np.arange(0.10, 0.91, 0.05):\n",
        "    y_pred_threshold = (y_prob_test >= threshold).astype(int)\n",
        "\n",
        "    threshold_results.append({\n",
        "        \"threshold\": round(threshold, 2),\n",
        "        \"accuracy\": accuracy_score(y_test, y_pred_threshold),\n",
        "        \"balanced_accuracy\": balanced_accuracy_score(y_test, y_pred_threshold),\n",
        "        \"precision_risk\": precision_score(y_test, y_pred_threshold, zero_division=0),\n",
        "        \"recall_risk\": recall_score(y_test, y_pred_threshold, zero_division=0),\n",
        "        \"f1_risk\": f1_score(y_test, y_pred_threshold, zero_division=0)\n",
        "    })\n",
        "\n",
        "threshold_df = pd.DataFrame(threshold_results)\n",
        "\n",
        "valid_thresholds = threshold_df[threshold_df[\"recall_risk\"] >= MIN_RECALL_RISK].copy()\n",
        "\n",
        "if len(valid_thresholds) > 0:\n",
        "    selected_threshold = valid_thresholds.sort_values(\n",
        "        by=[\"f1_risk\", \"balanced_accuracy\", \"precision_risk\"],\n",
        "        ascending=False\n",
        "    ).iloc[0][\"threshold\"]\n",
        "else:\n",
        "    selected_threshold = threshold_df.sort_values(\n",
        "        by=[\"balanced_accuracy\", \"f1_risk\"],\n",
        "        ascending=False\n",
        "    ).iloc[0][\"threshold\"]\n",
        "\n",
