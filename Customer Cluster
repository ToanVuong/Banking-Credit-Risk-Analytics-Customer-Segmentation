        "    \"avg_requested_amount_log\",\n",
        "    \"avg_disbursed_amount_log\",\n",
        "    \"avg_remaining_principal_log\",\n",
        "    \"avg_salary_log\",\n",
        "\n",
        "    # credit / affordability\n",
        "    \"avg_credit_score\",\n",
        "    \"avg_loan_to_income_ratio_clipped\",\n",
        "    \"avg_outstanding_ratio_clipped\",\n",
        "    \"customer_outstanding_ratio_clipped\",\n",
        "\n",
        "    # loan structure / repayment behavior\n",
        "    \"avg_loan_term_months\",\n",
        "    \"max_overdue_days_clipped\",\n",
        "    \"avg_overdue_days_clipped\",\n",
        "    \"overdue_count_clipped\",\n",
        "    \"late_payment_count_clipped\",\n",
        "\n",
        "    # demographic\n",
        "    \"age\"\n",
        "]\n",
        "\n",
        "risk_numeric_features = [c for c in risk_numeric_features if c in df.columns]\n",
        "\n",
        "risk_categorical_features = [\n",
        "    \"gender\",\n",
        "    \"age_group\",\n",
        "    \"city_name\",\n",
        "    \"job_name\",\n",
        "    \"residence_type\",\n",
        "    \"income_bracket\",\n",
        "    \"credit_score_group\"\n",
        "]\n",
        "\n",
        "risk_categorical_features = [c for c in risk_categorical_features if c in df.columns]\n",
        "\n",
        "print(\"Risk prediction numeric features:\")\n",
        "print(risk_numeric_features)\n",
        "\n",
        "print(\"\\nRisk prediction categorical features:\")\n",
        "print(risk_categorical_features)\n"
